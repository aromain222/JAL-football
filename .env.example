NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional app URL(s) for deployment-aware server action origins
# APP_URL=https://your-production-domain.com
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# Sportradar NCAA Football API (transfer portal sync)
# Get a key: https://developer.sportradar.com/
SPORTRADAR_API_KEY=
# Optional: trial | production (default: trial)
SPORTRADAR_ACCESS_LEVEL=trial
# Optional: transfer cycle year for synced players (default: current year)
# TRANSFER_YEAR=2026

# -------------------------------------------------------------------------
# Claude Computer Use — PFF Stats Downloader
# -------------------------------------------------------------------------
# Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=

# PFF premium account credentials (used by the computer-use script to log in)
PFF_EMAIL=
PFF_PASSWORD=

# Optional: season year for PFF exports (default: current year)
# PFF_SEASON=2025
