{
   "action": {
      "default_icon": "icon/128.png"
   },
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "pause": {
         "description": "Pause the recording",
         "global": true,
         "suggested_key": "Ctrl+Shift+9"
      }
   },
   "content_scripts": [ {
      "js": [ "content-scripts/brave.js" ],
      "matches": [ "*://localhost/brave", "https://*.cursorful.com/brave" ],
      "run_at": "document_start",
      "world": "ISOLATED"
   }, {
      "js": [ "content-scripts/licenses.js" ],
      "match_origin_as_fallback": true,
      "matches": [ "*://localhost/*", "https://*.cursorful.com/*" ],
      "run_at": "document_start",
      "world": "ISOLATED"
   }, {
      "js": [ "content-scripts/messaging.js" ],
      "matches": [ "*://localhost/*", "https://*.cursorful.com/*" ],
      "run_at": "document_start",
      "world": "ISOLATED"
   } ],
   "description": "Cursorful creates beautiful screen recordings with automatic zooms and pans that keep the viewer engaged.",
   "externally_connectable": {
      "matches": [ "*://localhost/*", "https://*.cursorful.com/*" ]
   },
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "icon/128.png",
      "48": "icon/48.png"
   },
   "incognito": "split",
   "key": "",
   "manifest_version": 3,
   "name": "Cursorful - Screen Recorder with Auto Zoom",
   "oauth2": {
      "client_id": "548244322037-huq4etmijh1vn5khenbso7flgip70l1e.apps.googleusercontent.com",
      "scopes": [ "https://www.googleapis.com/auth/userinfo.email" ]
   },
   "optional_permissions": [ "identity", "identity.email" ],
   "permissions": [ "desktopCapture", "offscreen", "tabs", "favicon", "scripting", "webNavigation", "system.display", "storage", "unlimitedStorage" ],
   "short_name": "Cursorful",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2.4.0",
   "web_accessible_resources": [ {
      "matches": [ "*://localhost/*", "https://*.cursorful.com/*" ],
      "resources": [ "/iframe.html", "/libav/*", "/_favicon/*" ]
   } ]
}
