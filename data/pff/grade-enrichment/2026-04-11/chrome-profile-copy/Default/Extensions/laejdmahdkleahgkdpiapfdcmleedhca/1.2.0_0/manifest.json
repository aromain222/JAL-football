{
   "action": {
      "default_icon": {
         "128": "logo.png",
         "16": "logo.png",
         "32": "logo.png",
         "48": "logo.png"
      }
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "all_frames": false,
      "js": [ "content-script.js" ],
      "match_about_blank": false,
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_end"
   } ],
   "default_locale": "en",
   "description": "This is a Chrome extension that simplifies event scheduling using natural language input right from your browser.",
   "host_permissions": [ "https://*.openai.com/", "https://*.googleapis.com/" ],
   "icons": {
      "128": "logo.png",
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "ChatGPT for Google Calendar",
   "options_page": "options.html",
   "permissions": [ "contextMenus", "activeTab", "tabs", "storage", "scripting", "windows", "notifications" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.2.0",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "logo.png" ]
   } ]
}
