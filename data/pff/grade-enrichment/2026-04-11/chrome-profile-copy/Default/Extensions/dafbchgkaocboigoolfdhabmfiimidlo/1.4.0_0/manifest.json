{
   "action": {
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "js/background.js"
   },
   "content_scripts": [ {
      "js": [ "js/content.js" ],
      "matches": [ "https://chatgpt.com/*" ]
   } ],
   "description": "Easily bulk select, delete, and archive ChatGPT conversations. Declutter your ChatGPT history in just a few clicks!",
   "host_permissions": [ "https://chatgpt.com/*" ],
   "icons": {
      "128": "public/icon.png",
      "16": "public/icon.png",
      "48": "public/icon.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "DeclutterGPT - Bulk Delete & Archive Chats",
   "permissions": [ "activeTab", "webRequest", "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.4.0"
}
