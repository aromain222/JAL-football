{
   "action": {
      "default_icon": "icons/Nikflix-48.png",
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "Main.js"
   },
   "content_scripts": [ {
      "css": [ "netflix-controller.css" ],
      "js": [ "Main.js" ],
      "matches": [ "*://*.netflix.com/*" ]
   } ],
   "description": "Bypass the account-sharing restrictions on Netflix.",
   "key": "",
   "manifest_version": 3,
   "name": "Nikflix (Household Bypass)",
   "permissions": [ "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.9.1",
   "web_accessible_resources": [ {
      "matches": [ "*://*.netflix.com/*" ],
      "resources": [ "netflix-seeker.js", "netflix-audioChange.js", "netflix-substitleChange.js" ]
   } ]
}
